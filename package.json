{
  "name": "@majidh1/jalalidatepicker",
  "description": "A lightweight and simple jalali datepicker.",
  "license": "MIT",
  "author": {
    "name": "Majid Houshyar"
  },
  "main": "dist/jalalidatepicker.min.js",
  "version": "1.0.0",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "date",
    "picker",
    "datepicker",
    "jalali",
    "persian",
    "jalalidatepicker",
    "calendar",
    "persiandatepicker",
    "farsi",
    "javascript",
    "front-end",
    "web"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/majidh1/JalaliDatePicker.git"
  },
  "bugs": {
    "url": "https://github.com/majidh1/JalaliDatePicker/issues",
    "email": "majidh1@live.com"
  },
  "homepage": "https://github.com/majidh1/JalaliDatePicker#readme",
  "scripts": {
    "prepublishOnly": "npm run build",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "dev": "vite --config vite.config.dev.js",
    "build:unminified": "tsc && vite build --config vite.config.js --mode unminified",
    "build:minified": "tsc && vite build --config vite.config.js --mode minified",
    "convert-dist-es5": "babel dist/jalalidatepicker.js --out-file dist/jalalidatepicker.js && terser dist/jalalidatepicker.js -o dist/jalalidatepicker.min.js --compress --mangle",
    "build": "npm run build:unminified && npm run build:minified && npm run convert-dist-es5",
    "preview": "vite preview --config vite.config.dev.js"
  },
  "devDependencies": {
    "@babel/cli": "7.28.3",
    "@babel/core": "7.28.5",
    "@babel/preset-env": "7.28.5",
    "@types/node": "24.10.0",
    "@typescript-eslint/eslint-plugin": "7.6.0",
    "@typescript-eslint/parser": "7.6.0",
    "eslint": "8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "sass": "1.93.3",
    "stylelint": "^16.25.0",
    "stylelint-config-standard-scss": "^13.1.0",
    "typescript": "5.9.3",
    "typescript-eslint": "7.6.0",
    "vite": "7.2.2",
    "vitest": "^4.1.8"
  }
}